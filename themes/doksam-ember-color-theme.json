{
  "$schema": "vscode://schemas/color-theme",
  "name": "Doksam Ember",
  "type": "light",
  "colors": {
    // ── 에디터 ──
    "editor.background": "#FAF9F6",
    "editor.foreground": "#1A1915",
    "editor.lineHighlightBackground": "#F3F1EC",
    "editor.selectionBackground": "#E5DDD1",
    "editor.selectionHighlightBackground": "#EAE4DA",
    "editor.wordHighlightBackground": "#E5DDD180",
    "editor.findMatchBackground": "#D9775750",
    "editor.findMatchHighlightBackground": "#D9775730",
    "editorCursor.foreground": "#D97757",
    "editorLineNumber.foreground": "#B5AFA5",
    "editorLineNumber.activeForeground": "#7A746A",
    "editorIndentGuide.background1": "#E8E4DD",
    "editorIndentGuide.activeBackground1": "#CFC8BC",
    "editorBracketMatch.background": "#E5DDD150",
    "editorBracketMatch.border": "#D97757",
    "editorGroup.border": "#E3DFD8",
    "editorWhitespace.foreground": "#DDD9D140",
    "editorRuler.foreground": "#E8E4DD",
    "editorOverviewRuler.border": "#E3DFD8",
    "editorGutter.addedBackground": "#7A8E5490",
    "editorGutter.modifiedBackground": "#D9775790",
    "editorGutter.deletedBackground": "#C0453590",
    "editorError.foreground": "#C04535",
    "editorWarning.foreground": "#C28B3A",
    "editorInfo.foreground": "#5A7E8E",

    // ── 사이드바 ──
    "sideBar.background": "#EEECE7",
    "sideBar.foreground": "#3D3935",
    "sideBar.border": "#E3DFD8",
    "sideBarTitle.foreground": "#5C5650",
    "sideBarSectionHeader.background": "#E6E3DC",
    "sideBarSectionHeader.foreground": "#5C5650",

    // ── 액티비티 바 ──
    "activityBar.background": "#E6E3DC",
    "activityBar.foreground": "#D97757",
    "activityBar.inactiveForeground": "#A39D93",
    "activityBar.border": "#E3DFD8",
    "activityBarBadge.background": "#D97757",
    "activityBarBadge.foreground": "#FFFFFF",

    // ── 타이틀 바 ──
    "titleBar.activeBackground": "#EEECE7",
    "titleBar.activeForeground": "#3D3935",
    "titleBar.inactiveBackground": "#EEECE7",
    "titleBar.inactiveForeground": "#A39D93",
    "titleBar.border": "#E3DFD8",

    // ── 탭 ──
    "tab.activeBackground": "#FAF9F6",
    "tab.activeForeground": "#1A1915",
    "tab.inactiveBackground": "#F0EDE8",
    "tab.inactiveForeground": "#7A746A",
    "tab.activeBorderTop": "#D97757",
    "tab.border": "#E3DFD8",
    "tab.hoverBackground": "#F5F3EE",
    "editorGroupHeader.tabsBackground": "#F0EDE8",
    "editorGroupHeader.tabsBorder": "#E3DFD8",

    // ── 패널 (터미널 등) ──
    "panel.background": "#F5F3EE",
    "panel.border": "#E3DFD8",
    "panelTitle.activeBorder": "#D97757",
    "panelTitle.activeForeground": "#3D3935",
    "panelTitle.inactiveForeground": "#A39D93",
    "terminal.background": "#F5F3EE",
    "terminal.foreground": "#1A1915",
    "terminal.ansiBlack": "#3D3935",
    "terminal.ansiRed": "#C04535",
    "terminal.ansiGreen": "#6B8E4A",
    "terminal.ansiYellow": "#C28B3A",
    "terminal.ansiBlue": "#5A7E8E",
    "terminal.ansiMagenta": "#8E6E99",
    "terminal.ansiCyan": "#4D8E8E",
    "terminal.ansiWhite": "#E8E4DD",
    "terminal.ansiBrightBlack": "#7A746A",
    "terminal.ansiBrightRed": "#D97757",
    "terminal.ansiBrightGreen": "#7A9E5A",
    "terminal.ansiBrightYellow": "#D9A04A",
    "terminal.ansiBrightBlue": "#6A8E9E",
    "terminal.ansiBrightMagenta": "#9E7EAA",
    "terminal.ansiBrightCyan": "#5A9E9E",
    "terminal.ansiBrightWhite": "#FAF9F6",

    // ── 상태 바 ──
    "statusBar.background": "#E6E3DC",
    "statusBar.foreground": "#5C5650",
    "statusBar.border": "#E3DFD8",
    "statusBar.debuggingBackground": "#D97757",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.noFolderBackground": "#E3DFD8",

    // ── 입력 / 드롭다운 ──
    "input.background": "#FFFFFF",
    "input.border": "#DDD9D1",
    "input.foreground": "#1A1915",
    "input.placeholderForeground": "#B5AFA5",
    "dropdown.background": "#FAF9F6",
    "dropdown.border": "#DDD9D1",
    "dropdown.foreground": "#1A1915",

    // ── 리스트 ──
    "list.activeSelectionBackground": "#E5DDD1",
    "list.activeSelectionForeground": "#1A1915",
    "list.hoverBackground": "#F0EDE8",
    "list.inactiveSelectionBackground": "#EAE4DA",
    "list.highlightForeground": "#D97757",
    "list.focusOutline": "#D9775780",

    // ── 버튼 ──
    "button.background": "#D97757",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#C96847",
    "button.secondaryBackground": "#E6E3DC",
    "button.secondaryForeground": "#3D3935",
    "button.secondaryHoverBackground": "#DDD9D1",

    // ── 스크롤바 ──
    "scrollbarSlider.background": "#CFC8BC50",
    "scrollbarSlider.hoverBackground": "#B5AFA580",
    "scrollbarSlider.activeBackground": "#7A746AA0",

    // ── 브레드크럼 ──
    "breadcrumb.background": "#FAF9F6",
    "breadcrumb.foreground": "#7A746A",
    "breadcrumb.focusForeground": "#D97757",
    "breadcrumb.activeSelectionForeground": "#3D3935",

    // ── 피크 뷰 ──
    "peekViewEditor.background": "#F5F3EE",
    "peekViewResult.background": "#F0EDE8",
    "peekViewTitle.background": "#E6E3DC",
    "peekView.border": "#D97757",

    // ── 뱃지 / 알림 ──
    "badge.background": "#D97757",
    "badge.foreground": "#FFFFFF",
    "notificationCenterHeader.background": "#E6E3DC",
    "notifications.background": "#FAF9F6",
    "notifications.border": "#E3DFD8",

    // ── 기타 UI ──
    "focusBorder": "#D9775780",
    "widget.border": "#E3DFD8",
    "widget.shadow": "#1A191510",
    "minimap.background": "#F5F3EE",
    "selection.background": "#E5DDD1",
    "textLink.foreground": "#D97757",
    "textLink.activeForeground": "#C96847",
    "progressBar.background": "#D97757",
    "debugToolBar.background": "#F0EDE8",
    "debugToolBar.border": "#E3DFD8",

    // ── Git 장식 ──
    "gitDecoration.addedResourceForeground": "#6B8E4A",
    "gitDecoration.modifiedResourceForeground": "#C28B3A",
    "gitDecoration.deletedResourceForeground": "#C04535",
    "gitDecoration.untrackedResourceForeground": "#5A7E8E",
    "gitDecoration.ignoredResourceForeground": "#B5AFA5",
    "gitDecoration.conflictingResourceForeground": "#D97757",

    // ── 에디터 위젯 ──
    "editorWidget.background": "#F5F3EE",
    "editorWidget.border": "#E3DFD8",
    "editorSuggestWidget.background": "#FAF9F6",
    "editorSuggestWidget.border": "#E3DFD8",
    "editorSuggestWidget.selectedBackground": "#E5DDD1",
    "editorSuggestWidget.highlightForeground": "#D97757",
    "editorHoverWidget.background": "#FAF9F6",
    "editorHoverWidget.border": "#E3DFD8",

    // ── 괄호 쌍 색상화 ──
    "editorBracketHighlight.foreground1": "#D97757",
    "editorBracketHighlight.foreground2": "#8E6E99",
    "editorBracketHighlight.foreground3": "#5A7E8E",
    "editorBracketHighlight.foreground4": "#C28B3A",
    "editorBracketHighlight.foreground5": "#6B8E4A",
    "editorBracketHighlight.foreground6": "#956D3A",

    // ── 커맨드 팔레트 ──
    "quickInput.background": "#FAF9F6",
    "quickInput.foreground": "#1A1915",
    "quickInputList.focusBackground": "#E5DDD1",
    "quickInputList.focusForeground": "#1A1915",
    "commandCenter.background": "#F0EDE8",
    "commandCenter.foreground": "#5C5650",
    "commandCenter.border": "#E3DFD8",
    "commandCenter.activeBorder": "#D97757",

    // ── 설정 에디터 ──
    "settings.headerForeground": "#3D3935",
    "settings.modifiedItemIndicator": "#D97757",
    "settings.checkboxBackground": "#FFFFFF",
    "settings.checkboxBorder": "#DDD9D1",
    "settings.textInputBackground": "#FFFFFF",
    "settings.textInputBorder": "#DDD9D1",
    "settings.numberInputBackground": "#FFFFFF",
    "settings.numberInputBorder": "#DDD9D1"
  },

  "tokenColors": [
    // ── 기본 ──
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#A39D93",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSDoc / Documentation",
      "scope": [
        "comment.block.documentation",
        "storage.type.class.jsdoc",
        "variable.other.jsdoc",
        "punctuation.definition.block.tag.jsdoc"
      ],
      "settings": {
        "foreground": "#B5AFA5",
        "fontStyle": "italic"
      }
    },

    // ── 키워드 ──
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C2582A"
      }
    },
    {
      "name": "Control flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#C2582A",
        "fontStyle": "italic"
      }
    },

    // ── 문자열 ──
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#697D45"
      }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#8B9E5A"
      }
    },
    {
      "name": "Template expression",
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#C2582A"
      }
    },

    // ── 숫자·상수·불리언 ──
    {
      "name": "Number",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#B35430"
      }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#B35430"
      }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant"],
      "settings": {
        "foreground": "#B35430"
      }
    },

    // ── 함수 ──
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#956D3A"
      }
    },
    {
      "name": "Method call",
      "scope": [
        "meta.method-call entity.name.function",
        "meta.function-call support.function"
      ],
      "settings": {
        "foreground": "#956D3A"
      }
    },
    {
      "name": "Function parameter",
      "scope": ["variable.parameter", "meta.parameter"],
      "settings": {
        "foreground": "#5C5650",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Arrow function",
      "scope": ["storage.type.function.arrow"],
      "settings": {
        "foreground": "#C2582A"
      }
    },

    // ── 타입·클래스 ──
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class",
        "entity.name.type.alias",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.module"
      ],
      "settings": {
        "foreground": "#7D6499"
      }
    },
    {
      "name": "Class name",
      "scope": ["entity.name.type.class", "entity.other.inherited-class"],
      "settings": {
        "foreground": "#7D6499"
      }
    },
    {
      "name": "Type parameter (generic)",
      "scope": ["entity.name.type.parameter"],
      "settings": {
        "foreground": "#8E7EAA"
      }
    },

    // ── 변수·속성 ──
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#3D3935"
      }
    },
    {
      "name": "Object property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6E5B47"
      }
    },
    {
      "name": "this / self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#C2582A",
        "fontStyle": "italic"
      }
    },

    // ── 연산자·구두점 ──
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#7A746A"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7A746A"
      }
    },
    {
      "name": "Brackets / Parens",
      "scope": [
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#5C5650"
      }
    },

    // ── 데코레이터 ──
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#8E6E99",
        "fontStyle": "italic"
      }
    },

    // ── HTML / JSX ──
    {
      "name": "HTML Tag",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#C2582A"
      }
    },
    {
      "name": "HTML Component (PascalCase)",
      "scope": ["support.class.component"],
      "settings": {
        "foreground": "#7D6499"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#956D3A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML Attribute Value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#697D45"
      }
    },

    // ── CSS ──
    {
      "name": "CSS Property",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#6E5B47"
      }
    },
    {
      "name": "CSS Value",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.color.css"
      ],
      "settings": {
        "foreground": "#B35430"
      }
    },
    {
      "name": "CSS Selector (class/id)",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#956D3A"
      }
    },
    {
      "name": "CSS Tag",
      "scope": ["entity.name.tag.css"],
      "settings": {
        "foreground": "#C2582A"
      }
    },
    {
      "name": "CSS Pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#8E6E99"
      }
    },
    {
      "name": "CSS Unit",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#B35430"
      }
    },

    // ── JSON ──
    {
      "name": "JSON Key",
      "scope": ["support.type.property-name.json"],
      "settings": {
        "foreground": "#6E5B47"
      }
    },
    {
      "name": "JSON String Value",
      "scope": ["string.quoted.double.json"],
      "settings": {
        "foreground": "#697D45"
      }
    },

    // ── Markdown ──
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#C2582A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#3D3935",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#5C5650",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#956D3A"
      }
    },
    {
      "name": "Markdown List",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#D97757"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote.markdown"],
      "settings": {
        "foreground": "#A39D93",
        "fontStyle": "italic"
      }
    },

    // ── 정규식 ──
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "keyword.operator.quantifier.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#B35430"
      }
    },
    {
      "name": "Regex Group",
      "scope": [
        "punctuation.definition.group.regexp",
        "keyword.operator.or.regexp"
      ],
      "settings": {
        "foreground": "#8E6E99"
      }
    },
    {
      "name": "Regex Character Class",
      "scope": [
        "constant.other.character-class.regexp",
        "punctuation.definition.character-class.regexp"
      ],
      "settings": {
        "foreground": "#5A7E8E"
      }
    },

    // ── SQL (백엔드에서 자주 사용) ──
    {
      "name": "SQL Keyword",
      "scope": ["keyword.other.sql", "keyword.other.DML.sql", "keyword.other.DDL.sql"],
      "settings": {
        "foreground": "#C2582A"
      }
    },

    // ── 지원 타입 ──
    {
      "name": "Built-in type / primitive",
      "scope": [
        "support.type.builtin",
        "support.type.primitive"
      ],
      "settings": {
        "foreground": "#5A7E8E"
      }
    },
    {
      "name": "Module / Namespace",
      "scope": [
        "entity.name.type.module",
        "support.module",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#7D6499"
      }
    },

    // ── Import path ──
    {
      "name": "Import source / module specifier",
      "scope": ["string.quoted.module", "meta.import string"],
      "settings": {
        "foreground": "#697D45"
      }
    },

    // ── Inserted / Deleted (diff) ──
    {
      "name": "Diff Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#6B8E4A"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#C04535"
      }
    },
    {
      "name": "Diff Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#C28B3A"
      }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#7D6499",
    "type": "#7D6499",
    "type.declaration": "#7D6499",
    "class": "#7D6499",
    "class.declaration": "#7D6499",
    "interface": "#7D6499",
    "interface.declaration": "#7D6499",
    "enum": "#7D6499",
    "enum.declaration": "#7D6499",
    "typeParameter": "#8E7EAA",
    "function": "#956D3A",
    "function.declaration": "#956D3A",
    "method": "#956D3A",
    "method.declaration": "#956D3A",
    "property": "#6E5B47",
    "property.declaration": "#6E5B47",
    "variable": "#3D3935",
    "variable.declaration": "#3D3935",
    "variable.readonly": "#3D3935",
    "variable.defaultLibrary": "#5A7E8E",
    "parameter": { "foreground": "#5C5650", "italic": true },
    "enumMember": "#B35430",
    "decorator": { "foreground": "#8E6E99", "italic": true }
  }
}
